# =====================================================================
# .env 範例檔 (.env.example)
# ---------------------------------------------------------------------
# 使用方式：
#   1. 把這個檔案複製成 .env       (cp .env.example .env)
#   2. 把下面每個值改成你自己的設定（尤其是密碼與 SECRET_KEY）
#   3. .env 內含真實密碼，「不要」commit 進 git（已被 .gitignore 忽略）
# =====================================================================

# --- PostgreSQL 資料庫設定
# 這三項必須和 docker-compose.yaml 裡 oj-postgres 容器、
# 以及 Django settings.py 的資料庫設定一致。
POSTGRES_DB=onlinejudge
POSTGRES_USER=onlinejudge
# 請改成強密碼
POSTGRES_PASSWORD=change-me-strong-password

# --- Django 設定
# DJANGO_SECRET_KEY：請自行產生一組新的，勿沿用範例值。
# 產生方法（在 Python 環境執行）：
# python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=generate-your-own-50-char-random-string

# Django 第一個管理員（superuser）的密碼，第一次啟動後務必修改。
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password

# 伺服器的IP或域名，否則會出現 DisallowedHost 錯誤。
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,your-server-ip

# 是否啟用 HTTPS 安全設定（secure cookie、強制轉址、HSTS 等）。
# 自行以本機 nginx 終結 TLS、或前面有 HTTPS 代理時設 true；
# 臨時架在沒有 HTTPS 的伺服器時設 false，網站才能正常運作。
USE_HTTPS=false

# nginx 要載入哪一份設定檔（放在 nginx/ 目錄）。
# 純 HTTP（預設、臨時 IP 伺服器）：           nginx.conf
# 由本機 nginx 終結 TLS（搭配 USE_HTTPS=true，
#   憑證放 nginx/certs/，見該目錄 README）：  nginx-ssl.conf
NGINX_CONF=nginx.conf

# 是否開啟 Django DEBUG 模式。
# 開發除錯時設 true；正式環境務必設 false（否則會洩漏錯誤細節與設定）。
DJANGO_DEBUG=false

# --- 時區
# docker-compose.yaml 預設 Asia/Taipei
TZ=Asia/Taipei
